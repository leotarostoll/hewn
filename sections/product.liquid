{% comment %}
  Hewn product page — main section.
  Gallery left, product info right. Accordion for details below the form.
{% endcomment %}

<div class="hewn-product">

  {%- comment -%} ── Gallery ── {%- endcomment -%}
  <div class="hewn-product__gallery">
    <div class="hewn-product__main-image">
      {%- if product.featured_image -%}
        {{
          product.featured_image
          | image_url: width: 2000
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            id: 'hewn-featured-image',
            class: 'hewn-product__featured-img',
            widths: '800, 1200, 1600, 2000',
            sizes: '(max-width: 749px) 100vw, 55vw',
            alt: product.featured_image.alt | escape
        }}
      {%- else -%}
        <div class="hewn-product__img-placeholder">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>

    {%- if product.images.size > 1 -%}
      <div class="hewn-product__thumbnails" role="list">
        {%- for image in product.images limit: 6 -%}
          <button
            class="hewn-product__thumb{% if forloop.first %} active{% endif %}"
            data-image-src="{{ image | image_url: width: 2000 }}"
            data-image-alt="{{ image.alt | escape }}"
            aria-label="View image {{ forloop.index }}"
            role="listitem"
          >
            {{
              image
              | image_url: width: 200
              | image_tag: loading: 'lazy', class: 'hewn-product__thumb-img', alt: image.alt | escape
            }}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ── Info ── {%- endcomment -%}
  <div class="hewn-product__info">

    {%- if product.type != blank -%}
      <div class="hewn-chip">{{ product.type }}</div>
    {%- endif -%}

    <h1 class="hewn-product__title">{{ product.title }}</h1>

    <p class="hewn-product__price" id="hewn-product-price">
      {%- assign current_variant = product.selected_or_first_available_variant -%}
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <span class="hewn-product__price--compare">{{ current_variant.compare_at_price | money }}</span>
      {%- endif -%}
      {{ current_variant.price | money }}
    </p>

    {%- if product.description != blank -%}
      <div class="hewn-product__description">
        {{ product.description }}
      </div>
    {%- endif -%}

    {%- comment -%} ── Add to cart form ── {%- endcomment -%}
    {%- form 'product', product, id: 'hewn-product-form' -%}

      {%- if product.variants.size > 1 -%}
        <div class="hewn-product__variants">
          {%- for option in product.options_with_values -%}
            <div class="hewn-product__option">
              <label class="hewn-product__option-label" for="option-{{ option.name | handleize }}">
                {{ option.name }}
              </label>
              <select name="id" id="option-{{ option.name | handleize }}" class="hewn-product__select">
                {%- for variant in product.variants -%}
                  <option
                    value="{{ variant.id }}"
                    {%- if variant == current_variant %} selected="selected"{% endif %}
                    {%- unless variant.available %} disabled{% endunless %}
                  >
                    {{ variant.title }}{% unless variant.available %} — Sold out{% endunless %}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      {%- endif -%}

      <div class="hewn-product__actions">
        <div class="hewn-product__quantity">
          <label for="hewn-quantity" class="visually-hidden">Quantity</label>
          <input
            type="number"
            name="quantity"
            id="hewn-quantity"
            min="1"
            value="1"
            class="hewn-product__qty-input"
          >
        </div>
        <button
          type="submit"
          class="hewn-btn hewn-btn--add-to-cart"
          {% unless product.available %}disabled{% endunless %}
        >
          {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
        </button>
      </div>

      <div class="hewn-product__payment-btns">
        {{ form | payment_button }}
      </div>

    {%- endform -%}

    {%- comment -%} ── Accordion details ── {%- endcomment -%}
    <div class="hewn-product__accordion">

      {%- if section.settings.directions != blank -%}
        <details class="hewn-accordion">
          <summary class="hewn-accordion__trigger">
            <span>Directions</span>
            <span class="hewn-accordion__icon" aria-hidden="true"></span>
          </summary>
          <div class="hewn-accordion__body">
            <p>{{ section.settings.directions }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- if section.settings.full_ingredients != blank -%}
        <details class="hewn-accordion">
          <summary class="hewn-accordion__trigger">
            <span>Full Ingredient List</span>
            <span class="hewn-accordion__icon" aria-hidden="true"></span>
          </summary>
          <div class="hewn-accordion__body">
            <p class="hewn-accordion__ingredients">{{ section.settings.full_ingredients }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- if section.settings.product_details != blank -%}
        <details class="hewn-accordion">
          <summary class="hewn-accordion__trigger">
            <span>Product Details</span>
            <span class="hewn-accordion__icon" aria-hidden="true"></span>
          </summary>
          <div class="hewn-accordion__body">
            <p>{{ section.settings.product_details }}</p>
          </div>
        </details>
      {%- endif -%}

      {%- if section.settings.warning != blank -%}
        <details class="hewn-accordion">
          <summary class="hewn-accordion__trigger">
            <span>Safety Information</span>
            <span class="hewn-accordion__icon" aria-hidden="true"></span>
          </summary>
          <div class="hewn-accordion__body">
            <p>{{ section.settings.warning }}</p>
          </div>
        </details>
      {%- endif -%}

    </div>

  </div>
</div>

<script>
  (function () {
    var thumbs = document.querySelectorAll('.hewn-product__thumb');
    var featuredImg = document.getElementById('hewn-featured-image');
    if (!featuredImg) return;
    thumbs.forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        featuredImg.src = this.dataset.imageSrc;
        featuredImg.alt = this.dataset.imageAlt;
        thumbs.forEach(function (t) { t.classList.remove('active'); });
        this.classList.add('active');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "settings": [
    {
      "type": "textarea",
      "id": "directions",
      "label": "Directions",
      "info": "How to use — shown in accordion"
    },
    {
      "type": "textarea",
      "id": "full_ingredients",
      "label": "Full ingredient list",
      "info": "Complete INCI list — shown in accordion"
    },
    {
      "type": "text",
      "id": "product_details",
      "label": "Product details",
      "info": "Size, weight, origin — shown in accordion"
    },
    {
      "type": "textarea",
      "id": "warning",
      "label": "Safety information",
      "info": "Warning text — shown in accordion"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
