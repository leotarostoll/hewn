<div class="hewn-routine">
  <div class="hewn-routine__header">
    {%- if section.settings.chip != blank -%}
      <div class="hewn-chip">{{ section.settings.chip }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="hewn-routine__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="hewn-routine__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="hewn-routine__products">
    {%- assign fallback_handles = 'charcoal-facial-cleanser,copper-peptide-moisture-complex' | split: ',' -%}
    {%- for i in (1..2) -%}
      {%- liquid
        assign step_image   = 'step_' | append: i | append: '_image'
        assign step_label   = 'step_' | append: i | append: '_label'
        assign step_desc    = 'step_' | append: i | append: '_description'
        assign step_link    = 'step_' | append: i | append: '_link'
        assign step_product = 'step_' | append: i | append: '_product'
        assign product_obj  = section.settings[step_product]
        assign fallback_handle = fallback_handles[forloop.index0]
      -%}

      {%- liquid
        if product_obj != blank
          assign p = product_obj
        elsif fallback_handle != blank
          assign p_candidate = all_products[fallback_handle]
          if p_candidate.id != blank
            assign p = p_candidate
          else
            assign p = nil
          endif
        else
          assign p = nil
        endif

        if p != nil
          assign step_url   = p.url
          assign step_name  = p.title
          assign step_blurb = p.description | strip_html | truncate: 120
          assign step_price = p.price | money
          assign step_type  = p.type
          if section.settings[step_image] != blank
            assign step_img = section.settings[step_image]
          elsif p.featured_image != blank
            assign step_img = p.featured_image
          else
            assign step_img = nil
          endif
        else
          assign step_url   = section.settings[step_link] | default: '/collections/all'
          assign step_name  = section.settings[step_label]
          assign step_blurb = section.settings[step_desc]
          assign step_price = nil
          assign step_type  = nil
          assign step_img   = section.settings[step_image]
        endif
      -%}

      <a href="{{ step_url }}" class="hewn-routine__step">
        <div class="hewn-routine__step-image">
          {%- if step_img != nil -%}
            {{
              step_img
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                class: 'hewn-routine__img',
                widths: '400, 600, 800',
                sizes: '(max-width: 749px) 100vw, 50vw',
                alt: step_name | escape
            }}
          {%- else -%}
            <div class="hewn-routine__img-placeholder">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
          <span class="hewn-routine__step-badge">Step 0{{ i }}</span>
        </div>

        <div class="hewn-routine__step-info">
          {%- if step_type != blank -%}
            <span class="hewn-routine__step-type">{{ step_type }}</span>
          {%- endif -%}
          {%- if step_name != blank -%}
            <h3 class="hewn-routine__step-name">{{ step_name }}</h3>
          {%- endif -%}
          {%- if step_blurb != blank -%}
            <p class="hewn-routine__step-desc">{{ step_blurb }}</p>
          {%- endif -%}
          <div class="hewn-routine__step-footer">
            {%- if step_price != blank -%}
              <span class="hewn-routine__step-price">{{ step_price }}</span>
            {%- endif -%}
            <span class="hewn-btn hewn-btn--text">Shop Now &rarr;</span>
          </div>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "The Routine",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "chip",
      "label": "Chip label",
      "default": "The Routine"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Two Steps."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "That's it. No 12-step routine. No guesswork."
    },
    {
      "type": "header",
      "content": "Step 1 — Cleanser"
    },
    {
      "type": "product",
      "id": "step_1_product",
      "label": "Link to product (auto-fills title, description, URL)"
    },
    {
      "type": "image_picker",
      "id": "step_1_image",
      "label": "Override product image"
    },
    {
      "type": "text",
      "id": "step_1_label",
      "label": "Fallback product name",
      "default": "Charcoal Facial Cleanser"
    },
    {
      "type": "textarea",
      "id": "step_1_description",
      "label": "Fallback description",
      "default": "Activated charcoal draws out impurities while aloe vera soothes. A clean slate for everything that follows."
    },
    {
      "type": "url",
      "id": "step_1_link",
      "label": "Fallback link URL"
    },
    {
      "type": "header",
      "content": "Step 2 — Moisturizer"
    },
    {
      "type": "product",
      "id": "step_2_product",
      "label": "Link to product (auto-fills title, description, URL)"
    },
    {
      "type": "image_picker",
      "id": "step_2_image",
      "label": "Override product image"
    },
    {
      "type": "text",
      "id": "step_2_label",
      "label": "Fallback product name",
      "default": "Copper Peptide Moisture Complex"
    },
    {
      "type": "textarea",
      "id": "step_2_description",
      "label": "Fallback description",
      "default": "Bioactive copper peptides and botanical extracts to support skin renewal. Lightweight enough for daily use."
    },
    {
      "type": "url",
      "id": "step_2_link",
      "label": "Fallback link URL"
    }
  ],
  "presets": [
    {
      "name": "The Routine"
    }
  ]
}
{% endschema %}
