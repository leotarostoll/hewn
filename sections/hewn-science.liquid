<div class="hewn-science">
  <div class="hewn-science__header">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hewn-eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="hewn-science__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>

  <div class="hewn-science__pillars">
    {%- for i in (1..3) -%}
      {%- liquid
        assign pillar_title = 'pillar_' | append: i | append: '_title'
        assign pillar_body  = 'pillar_' | append: i | append: '_body'
      -%}
      <div class="hewn-science__pillar">
        <span class="hewn-science__pillar-number">0{{ i }}</span>
        {%- if section.settings[pillar_title] != blank -%}
          <h3 class="hewn-science__pillar-title">{{ section.settings[pillar_title] }}</h3>
        {%- endif -%}
        {%- if section.settings[pillar_body] != blank -%}
          <p class="hewn-science__pillar-body">{{ section.settings[pillar_body] }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "The Science",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Hewn Difference"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why It Works."
    },
    {
      "type": "header",
      "content": "Pillar 1"
    },
    {
      "type": "text",
      "id": "pillar_1_title",
      "label": "Title",
      "default": "Peptide Technology"
    },
    {
      "type": "textarea",
      "id": "pillar_1_body",
      "label": "Body",
      "default": "Signal peptides mimic the body's natural repair signals, triggering collagen synthesis and cellular regeneration."
    },
    {
      "type": "header",
      "content": "Pillar 2"
    },
    {
      "type": "text",
      "id": "pillar_2_title",
      "label": "Title",
      "default": "Topical Delivery"
    },
    {
      "type": "textarea",
      "id": "pillar_2_body",
      "label": "Body",
      "default": "Our proprietary absorption complex ensures peptides penetrate the skin barrier — where they can actually work."
    },
    {
      "type": "header",
      "content": "Pillar 3"
    },
    {
      "type": "text",
      "id": "pillar_3_title",
      "label": "Title",
      "default": "Proven Results"
    },
    {
      "type": "textarea",
      "id": "pillar_3_body",
      "label": "Body",
      "default": "Clinical-grade efficacy without the clinical setting. Hewn peptides deliver measurable improvements in 4–8 weeks."
    }
  ],
  "presets": [
    {
      "name": "The Science"
    }
  ]
}
{% endschema %}
