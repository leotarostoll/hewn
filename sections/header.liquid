<header class="hewn-header" role="banner">
  <div class="hewn-header__inner">

    {%- comment -%} Logo / wordmark {%- endcomment -%}
    <a href="{{ routes.root_url }}" class="hewn-header__logo" aria-label="{{ shop.name }} — home">
      {{- shop.name | upcase -}}
    </a>

    {%- comment -%} Primary nav {%- endcomment -%}
    <nav class="hewn-header__nav" aria-label="Main navigation">
      {%- for link in section.settings.menu.links -%}
        <a
          href="{{ link.url }}"
          class="hewn-header__nav-link{% if link.active %} hewn-header__nav-link--active{% endif %}"
          {% if link.active %}aria-current="page"{% endif %}
        >
          {{- link.title -}}
        </a>
      {%- endfor -%}
    </nav>

    {%- comment -%} Actions {%- endcomment -%}
    <div class="hewn-header__actions">
      {%- if shop.customer_accounts_enabled -%}
        <shopify-account menu="{{ section.settings.customer_account_menu }}" class="hewn-header__icon-btn" aria-label="Account">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="hewn-header__icon-btn hewn-header__cart" aria-label="Cart{% if cart.item_count > 0 %} ({{ cart.item_count }} item{{ cart.item_count | plural: '', 's' }}){% endif %}">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {%- if cart.item_count > 0 -%}
          <span class="hewn-header__cart-badge" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
