{%- liquid
  assign hair_product_setting = section.settings.product
  if hair_product_setting != blank
    assign hair_product = hair_product_setting
  else
    assign hair_candidate = all_products['hair-regrowth-peptide-complex']
    if hair_candidate.id != blank
      assign hair_product = hair_candidate
    endif
  endif

  if hair_product != blank
    assign hair_url = hair_product.url
    if section.settings.image != blank
      assign hair_img = section.settings.image
    elsif hair_product.featured_image != blank
      assign hair_img = hair_product.featured_image
    else
      assign hair_img = nil
    endif
    assign hair_price = hair_product.price | money
  else
    assign hair_url = section.settings.button_link | default: '/collections/all'
    assign hair_img = section.settings.image
    assign hair_price = nil
  endif
-%}

<div class="hewn-hair full-width">
  <div class="hewn-hair__inner">
    <div class="hewn-hair__content">
      {%- if section.settings.chip != blank -%}
        <div class="hewn-chip">{{ section.settings.chip }}</div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hewn-hair__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="hewn-hair__body">{{ section.settings.body }}</p>
      {%- endif -%}
      <div class="hewn-hair__footer">
        {%- if hair_price != blank -%}
          <span class="hewn-hair__price">{{ hair_price }}</span>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ hair_url }}" class="hewn-btn hewn-btn--ghost">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="hewn-hair__image">
      {%- if hair_img != nil -%}
        {{
          hair_img
          | image_url: width: 1000
          | image_tag:
            loading: 'lazy',
            class: 'hewn-hair__img',
            widths: '500, 750, 1000',
            sizes: '(max-width: 749px) 100vw, 50vw',
            alt: section.settings.heading | escape
        }}
      {%- else -%}
        <div class="hewn-hair__img-placeholder">
          {{ 'product-2' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hair Growth Spotlight",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "chip",
      "label": "Chip label",
      "default": "Beyond Skincare"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Peptides for\nHair Growth."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body copy",
      "default": "The same peptide technology that transforms your skin is now targeting hair follicle health — stimulating growth at the root, without a single injection."
    },
    {
      "type": "product",
      "id": "product",
      "label": "Link to product (auto-resolves URL and image)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Hair Serum"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Fallback button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Override product image"
    }
  ],
  "presets": [
    {
      "name": "Hair Growth Spotlight"
    }
  ]
}
{% endschema %}
