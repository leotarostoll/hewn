<div class="hewn-bento">
  <div class="hewn-bento__header">
    {%- if section.settings.chip != blank -%}
      <div class="hewn-chip">{{ section.settings.chip }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="hewn-bento__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="hewn-bento__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="hewn-bento__grid">

    {%- comment -%} Card 1 — Wide, main technology card {%- endcomment -%}
    <div class="hewn-bento-card hewn-bento-card--col-7 hewn-bento-card--glow">
      <p class="hewn-bento-card__label">{{ section.settings.card_1_label | default: '01' }}</p>
      <h3 class="hewn-bento-card__title">{{ section.settings.card_1_title | default: 'Peptide Technology' }}</h3>
      <p class="hewn-bento-card__body">{{ section.settings.card_1_body | default: 'Signal peptides mimic the body\'s own repair mechanisms, triggering collagen synthesis and cellular regeneration at the source.' }}</p>
    </div>

    {%- comment -%} Card 2 — Accent metric card {%- endcomment -%}
    <div class="hewn-bento-card hewn-bento-card--col-5 hewn-bento-card--accent hewn-bento-card--row-2">
      <div class="hewn-bento-card__metric">{{ section.settings.metric_value | default: '94%' }}</div>
      <p class="hewn-bento-card__metric-label">{{ section.settings.metric_label | default: 'of users saw visible improvement in fine lines within 4 weeks' }}</p>
    </div>

    {%- comment -%} Card 3 {%- endcomment -%}
    <div class="hewn-bento-card hewn-bento-card--col-4">
      <p class="hewn-bento-card__label">{{ section.settings.card_3_label | default: '02' }}</p>
      <h3 class="hewn-bento-card__title">{{ section.settings.card_3_title | default: 'Topical Delivery' }}</h3>
      <p class="hewn-bento-card__body">{{ section.settings.card_3_body | default: 'Our absorption complex ensures peptides penetrate the skin barrier — where they actually work.' }}</p>
    </div>

    {%- comment -%} Card 4 {%- endcomment -%}
    <div class="hewn-bento-card hewn-bento-card--col-3">
      <p class="hewn-bento-card__label">{{ section.settings.card_4_label | default: '03' }}</p>
      <h3 class="hewn-bento-card__title">{{ section.settings.card_4_title | default: 'No Needles' }}</h3>
      <p class="hewn-bento-card__body">{{ section.settings.card_4_body | default: 'Injectable-grade efficacy. Zero pain. Zero clinic visits.' }}</p>
    </div>

    {%- comment -%} Card 5 {%- endcomment -%}
    <div class="hewn-bento-card hewn-bento-card--col-5">
      <p class="hewn-bento-card__label">{{ section.settings.card_5_label | default: '04' }}</p>
      <h3 class="hewn-bento-card__title">{{ section.settings.card_5_title | default: 'Two Steps. That\'s It.' }}</h3>
      <p class="hewn-bento-card__body">{{ section.settings.card_5_body | default: 'Cleanser. Moisturizer. No 12-step routine. No guesswork. Engineered to be the only two products your skin needs.' }}</p>
    </div>

  </div>
</div>

